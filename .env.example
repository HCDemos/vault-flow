# Path to the Vault audit log on the host
AUDIT_LOG_PATH=/var/log/vault/audit.log

# Host port to expose vault-flow on
PORT=9000

# Number of past events to show on page load
HISTORY_LIMIT=200

# Comma-separated KV v2 mount names to watch
# KV_MOUNTS=secret,demo

# /ingest endpoint authentication (for HCP Vault Dedicated HTTP push)
# Choose ONE method. Leave both blank to accept all requests (trusted network only).
# Bearer token (recommended):
# INGEST_BEARER_TOKEN=change-me
# HTTP Basic auth:
# INGEST_USERNAME=vault-flow
# INGEST_PASSWORD=change-me
